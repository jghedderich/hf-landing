---
import {
  localizedPath,
  useTranslations,
  type Locale,
} from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<footer class="border-t border-stone-200/60 bg-paper text-muted">
  <div class="mx-auto max-w-5xl px-5 py-12">
    <p class="max-w-md font-serif text-base leading-relaxed">
      {t.footer.tagline}
    </p>

    <nav
      class="mt-8 flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs uppercase tracking-wider"
      aria-label="Footer"
    >
      <a
        href={localizedPath('/#work', locale)}
        class="no-underline transition-colors hover:text-accent">{t.footer.work}</a
      >
      <a
        href={localizedPath('/#contact', locale)}
        class="no-underline transition-colors hover:text-accent">{t.nav.getInTouch}</a
      >
      <a
        href={localizedPath('/privacy', locale)}
        class="no-underline transition-colors hover:text-accent">{t.footer.privacy}</a
      >
    </nav>

    <p class="mt-10 font-mono text-xs text-muted">
      © {new Date().getFullYear()} HF Software
    </p>
  </div>
</footer>
