---
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="contact" class="scroll-mt-24 border-t border-stone-200/60 bg-white/30 py-16 sm:py-20">
  <div class="fade-up mx-auto max-w-5xl px-5">
    <h2 class="font-sans text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      {t.contact.title}
    </h2>
    <p class="mt-3 max-w-lg font-serif text-lg leading-relaxed text-muted">
      {t.contact.intro}
    </p>

    <form
      id="contact-form"
      class="mt-10 max-w-xl space-y-5"
      data-locale={locale}
      data-success={t.contact.success}
      data-error={t.contact.error}
      data-sending={t.contact.sending}
    >
      <div>
        <label for="name" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600">
          {t.contact.name}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="w-full rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        />
      </div>

      <div>
        <label for="email" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600">
          {t.contact.email}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        />
      </div>

      <div>
        <label for="referral" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600">
          {t.contact.referral}
        </label>
        <select
          id="referral"
          name="referral"
          required
          class="w-full rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        >
          {
            Object.entries(t.contact.referralOptions).map(([value, label]) => (
              <option value={value}>{label}</option>
            ))
          }
        </select>
      </div>

      <div id="referral-other-wrap" class="hidden">
        <label
          for="referralOther"
          class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600"
        >
          {t.contact.referralOther}
        </label>
        <input
          type="text"
          id="referralOther"
          name="referralOther"
          class="w-full rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        />
      </div>

      <div>
        <label for="companyStage" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600">
          {t.contact.companyStage}
        </label>
        <select
          id="companyStage"
          name="companyStage"
          required
          class="w-full rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        >
          <option value="" disabled selected hidden></option>
          {
            Object.entries(t.contact.stageOptions).map(([value, label]) => (
              <option value={value}>{label}</option>
            ))
          }
        </select>
      </div>

      <div>
        <label for="message" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-stone-600">
          {t.contact.message}
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          class="w-full resize-y rounded-lg border border-stone-200 bg-paper px-4 py-3 font-serif text-ink outline-none transition-colors focus:border-accent focus:ring-2 focus:ring-accent/20"
        ></textarea>
      </div>

      <input type="hidden" name="locale" value={locale} />

      <button
        type="submit"
        id="contact-submit"
        class="rounded-full bg-accent px-6 py-3 font-sans text-sm font-medium text-white transition-transform hover:scale-[1.02] active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
      >
        {t.contact.submit}
      </button>

      <p id="contact-status" class="hidden font-serif text-base" role="status"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const referral = document.getElementById('referral') as HTMLSelectElement | null;
  const referralOtherWrap = document.getElementById('referral-other-wrap');
  const status = document.getElementById('contact-status');
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  referral?.addEventListener('change', () => {
    if (!referralOtherWrap) return;
    referralOtherWrap.classList.toggle('hidden', referral.value !== 'other');
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !status || !submitBtn) return;

    const defaultLabel = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = form.dataset.sending ?? 'Sending…';
    status.className = 'hidden font-serif text-base';
    status.textContent = '';

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error('Request failed');

      form.reset();
      referralOtherWrap?.classList.add('hidden');
      status.className = 'font-serif text-base text-accent';
      status.textContent = form.dataset.success ?? 'Thank you.';
    } catch {
      status.className = 'font-serif text-base text-red-600';
      status.textContent = form.dataset.error ?? 'Something went wrong.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = defaultLabel;
    }
  });
</script>
