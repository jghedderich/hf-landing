---
import { Image } from 'astro:assets';
import { localizedPath, useTranslations, type Locale } from '../i18n/ui';
import { caseStudyImages } from '../data/case-study-images';

interface Props {
  slug: string;
  title: string;
  sector: string;
  locale: Locale;
}

const { slug, title, sector, locale } = Astro.props;
const t = useTranslations(locale);
const images = caseStudyImages[slug];
---

<a
  href={localizedPath(`/case-studies/${slug}`, locale)}
  class="group fade-up block no-underline"
>
  <article
    class="overflow-hidden rounded-2xl border border-stone-200/80 bg-white/50 transition-all duration-300 hover:border-accent/30 hover:shadow-md hover:shadow-accent/5"
  >
    {
      images && (
        <div class="aspect-[16/10] overflow-hidden bg-stone-100">
          <Image
            src={images.card}
            alt=""
            class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
            widths={[400, 640, 800]}
            sizes="(max-width: 640px) 100vw, 50vw"
          />
        </div>
      )
    }
    <div class="p-5 sm:p-6">
      <p class="font-mono text-xs uppercase tracking-wider text-muted">{sector}</p>
      <h3 class="mt-2 font-sans text-xl font-semibold tracking-tight text-ink">
        {title}
      </h3>
      <p
        class="mt-3 font-sans text-sm font-medium text-accent transition-transform group-hover:translate-x-0.5"
      >
        {t.work.viewCaseStudy} →
      </p>
    </div>
  </article>
</a>
