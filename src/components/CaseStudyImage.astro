---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  variant?: 'hero' | 'card';
  class?: string;
}

const {
  src,
  alt = '',
  variant = 'hero',
  class: className = '',
} = Astro.props;

const isCard = variant === 'card';
const widths = isCard ? [400, 640, 800] : [640, 960, 1200];
const sizes = isCard
  ? '(max-width: 640px) 100vw, 50vw'
  : '(max-width: 768px) 100vw, 768px';
---

<div
  class:list={[
    'overflow-hidden bg-white',
    !isCard && 'shadow-lg rounded-lg border shadow-md p-2',
    className,
  ]}
>
  <Image
    src={src}
    alt={alt}
    class:list={['block w-full shadow-lg border rounded-md', isCard && 'aspect-[16/10] object-cover object-left p-0']}
    widths={widths}
    sizes={sizes}
  />
  </div>
