---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SketchUnderline from '../../components/SketchUnderline.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Locale } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);

export const prerender = true;

const caseStudies = (await getCollection('caseStudies'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    slug: entry.data.slug,
    title: entry.data.title[locale],
    sector: entry.data.sector[locale],
  }));
---

<BaseLayout>
  <section class="mx-auto max-w-5xl px-5 pb-16 pt-12 sm:pt-20">
    <div class="fade-up max-w-2xl">
      <h1
        class="font-sans text-3xl font-semibold leading-tight tracking-tight text-ink sm:text-4xl md:text-5xl"
      >
        {t.hero.headline}
      </h1>
      <SketchUnderline class="mt-4" width={180} />
      <p class="mt-6 font-serif text-lg leading-relaxed text-muted sm:text-xl">
        {t.hero.subline}
      </p>
      <a
        href="#contact"
        class="mt-8 inline-block rounded-full bg-accent px-6 py-3 font-sans text-sm font-medium text-white no-underline transition-transform hover:scale-[1.02] active:scale-[0.98]"
      >
        {t.hero.cta}
      </a>
    </div>
  </section>

  <section id="work" class="scroll-mt-24 border-t border-stone-200/60 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-5">
      <h2
        class="fade-up font-sans text-2xl font-semibold tracking-tight text-ink sm:text-3xl"
      >
        {t.work.title}
      </h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-2">
        {
          caseStudies.map((study) => (
            <CaseStudyCard
              slug={study.slug}
              title={study.title}
              sector={study.sector}
              locale={locale}
            />
          ))
        }
      </div>
    </div>
  </section>

  <ContactForm locale={locale} />
</BaseLayout>
